# ===========================================
# AKAAR Environment Configuration
# Supabase-powered backend
# ===========================================

# ---------------------------
# Supabase (REQUIRED)
# Find these in: https://supabase.com/dashboard/project/mpdjjxkkjuhnqcynclin/settings/api
# ---------------------------
NEXT_PUBLIC_SUPABASE_URL=https://mpdjjxkkjuhnqcynclin.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---------------------------
# App URL
# ---------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------
# OAuth Providers
# Configure redirect URLs in: https://supabase.com/dashboard/project/mpdjjxkkjuhnqcynclin/auth/providers
# ---------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ---------------------------
# Payment Gateway (Razorpay)
# ---------------------------
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ---------------------------
# File Storage (AWS S3)
# ---------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_bucket_name

# ---------------------------
# Email (SMTP)
# ---------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# ---------------------------
# Error Monitoring (Sentry)
# ---------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

NODE_ENV=development
